# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# WhatsApp Business API settings
WHATSAPP_API_URL=https://graph.facebook.com/v16.0/<PHONE_NUMBER_ID>/messages
WHATSAPP_ACCESS_TOKEN=your_whatsapp_api_token
WHATSAPP_GROUP_ID=whatsapp_group_id
ADMIN_PHONE_NUMBER=admin_phone_number_in_whatsapp_format

# Auction settings
CHECK_INTERVAL_SECONDS=5

# Admin auth for protected endpoints
ADMIN_SECRET=my_admin_secret
