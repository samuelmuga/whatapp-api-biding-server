# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# WhatsApp provider: "whapi" (Whapi.cloud, supports groups) or "meta"
# (official WhatsApp Cloud API / graph.facebook.com, DMs only - no groups).
# If omitted it is auto-detected from WHATSAPP_API_URL.
WHATSAPP_PROVIDER=whapi

# WhatsApp API settings
# - Whapi:  https://gate.whapi.cloud/
# - Meta:   https://graph.facebook.com/v19.0/<PHONE_NUMBER_ID>/messages
WHATSAPP_API_URL=https://gate.whapi.cloud/
WHATSAPP_ACCESS_TOKEN=your_whatsapp_api_token

# Group JID for announcements (Whapi only). Must be numeric, e.g. 1234567890@g.us
WHATSAPP_GROUP_ID=1234567890@g.us
ADMIN_PHONE_NUMBER=admin_phone_number_in_whatsapp_format

# Auction settings
CHECK_INTERVAL_SECONDS=5

# Admin auth for protected endpoints
ADMIN_SECRET=my_admin_secret
